<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="768.0" prefWidth="1024.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <VBox prefWidth="100.0" spacing="5.0" style="-fx-background-color: white;" BorderPane.alignment="CENTER">
            <children>
                <MenuBar>
                    <menus>
                        <Menu mnemonicParsing="false" text="Options">
                            <items>
                                <Menu mnemonicParsing="false" text="Update Store">
                                    <items>
                                        <MenuItem mnemonicParsing="false" text="Add Book" />
                                        <MenuItem mnemonicParsing="false" text="Add CD" />
                                        <MenuItem mnemonicParsing="false" text="Add DVD" />
                                    </items>
                                </Menu>
                                <MenuItem mnemonicParsing="false" text="View Store" />
                                <MenuItem mnemonicParsing="false" text="View Cart" />
                            </items>
                        </Menu>
                    </menus>
                </MenuBar>
                <Label text="CART" textFill="#009688">
                    <font>
                        <Font name="System Bold" size="48.0" />
                    </font>
                    <padding>
                        <Insets left="20.0" />
                    </padding>
                </Label>
            </children>
        </VBox>
    </top>
    <center>
        <VBox prefHeight="200.0" prefWidth="100.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #ddd; -fx-border-radius: 10;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" prefWidth="200.0" spacing="15.0">
                    <padding>
                        <Insets bottom="10.0" top="10.0" />
                    </padding>
                    <children>
                        <Label text="Filter:">
                            <font>
                                <Font name="System Italic" size="15.0" />
                            </font>
                        </Label>
                        <TextField fx:id="tfFilter" prefWidth="250.0" promptText="Search here..." style="-fx-background-radius: 15;" />
                        <RadioButton fx:id="radioBtnFilterId" mnemonicParsing="false" selected="true" text="By ID">
                            <toggleGroup>
                                <ToggleGroup fx:id="filterCategory" />
                            </toggleGroup>
                        </RadioButton>
                        <RadioButton fx:id="radioBtnFilterTitle" mnemonicParsing="false" text="By Title" toggleGroup="$filterCategory" />
                    </children>
                </HBox>
                <TableView fx:id="tblMedia" style="-fx-selection-bar: #e0f2f1;">
                    <columns>
                        <TableColumn fx:id="colMediaTitle" prefWidth="75.0" text="Title" />
                        <TableColumn fx:id="colMediaCategory" prefWidth="75.0" text="Category" />
                        <TableColumn fx:id="colMediaCost" prefWidth="75.0" text="Cost ($)" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
                <ButtonBar prefHeight="40.0" prefWidth="200.0">
                    <buttons>
                        <Button fx:id="btnPlay" mnemonicParsing="false" onAction="#btnPlayPressed" style="-fx-background-radius: 15;" text="Play" />
                        <Button fx:id="btnRemove" mnemonicParsing="false" onAction="#btnRemovePressed" style="-fx-background-radius: 15;" text="Remove" />
                    </buttons>
                </ButtonBar>
            </children>
            <BorderPane.margin>
                <Insets bottom="20.0" left="20.0" right="10.0" top="20.0" />
            </BorderPane.margin>
        </VBox>
    </center>
    <right>
        <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="240.0" spacing="30.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #ddd; -fx-border-radius: 10;" BorderPane.alignment="CENTER">
            <padding>
                <Insets left="10.0" right="10.0" top="50.0" />
            </padding>
            <children>
                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <Label text="Total:">
                            <font>
                                <Font name="System Bold" size="28.0" />
                            </font>
                        </Label>
                        <Label fx:id="lblTotalCost" text="0 $" textFill="#009688">
                            <font>
                                <Font name="System Bold" size="28.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>
                <Button mnemonicParsing="false" prefHeight="60.0" prefWidth="200.0" style="-fx-background-color: #ff5252; -fx-text-fill: white; -fx-background-radius: 30; -fx-cursor: hand; -fx-font-weight: bold;" text="Place Order">
                    <font>
                        <Font size="24.0" />
                    </font>
                </Button>
            </children>
            <BorderPane.margin>
                <Insets bottom="20.0" left="10.0" right="20.0" top="20.0" />
            </BorderPane.margin>
        </VBox>
    </right>
</BorderPane>